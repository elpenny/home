#!/bin/sh

case ":${PATH}:" in
    *:"$HOME/.local/bin":*) ;;
    *) export PATH="$HOME/.local/bin:$PATH" ;;
esac

case ":${PATH}:" in
    *:"$HOME/bin":*) ;;
    *) [ -d "$HOME/bin" ] && export PATH="$HOME/bin:$PATH" ;;
esac

case ":${PATH}:" in
    *:"$HOME/.dotnet":*) ;;
    *) [ -d "$HOME/.dotnet" ] && export PATH="$HOME/.dotnet:$PATH" ;;
esac
